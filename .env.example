# Claude API (required for Claude provider)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-xxx
# CLAUDE_MODEL=claude-sonnet-4-5-20250514  # Model for Claude provider (optional, uses SDK default)
# CLAUDE_MAX_TURNS=30                       # Max tool-use turns (optional, uses SDK default)
# CLAUDE_MAX_BUDGET_USD=2.0                 # Max cost per conversation (optional, uses SDK default)

# GitHub (Claude Code uses gh CLI, needs GH_TOKEN in env)
GH_TOKEN=ghp_xxx

# Sentry tool (optional — enables sentry_query for Chat)
# SENTRY_BASE_URL=https://sentry.io
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# Web tools (optional)
# BRAVE_API_KEY=BSA_xxx                # Enables web_search tool
# FIRECRAWL_API_KEY=fc-xxx             # Enables rich HTML→Markdown in web_fetch

# Server
PORT=8080
# LOG_LEVEL=info                    # debug | info | warn | error (default: info)

# Workspace — isolated sandbox for AI file operations (default: data/workspace)
# IMPORTANT: Do NOT point this at the project root or any directory containing
# .env / secrets. The AI's file_read/file_write tools are sandboxed to this path.
# WORKSPACE_DIR=data/workspace

# Bash exec tool
# BASH_EXEC_ENABLED=true             # Enable/disable bash_exec tool (default: true)
# BASH_EXEC_TIMEOUT=120              # Default timeout in seconds (default: 120)
# BASH_EXEC_MAX_TIMEOUT=600          # Max allowed timeout in seconds (default: 600)
# BASH_EXEC_ALLOWED_COMMANDS=git,gh,npm,node,curl,...  # Comma-separated command allowlist

# Skills (extra directories for ClawHub-installed skills, comma-separated)
# SKILLS_EXTRA_DIRS=skills_extra

# Chat Assistant
# CHAT_PROVIDER=claude              # Provider name (default: "claude", or any registered name)
# CHAT_MODEL=deepseek-chat          # Model name (for generic provider)
# CHAT_API_BASE=https://api.deepseek.com/v1  # API base URL (for generic)
# CHAT_API_KEY=sk-xxx               # API key (for generic provider)
# CHAT_USERS=user1:token1,user2:token2  # Authenticated users (user:token pairs, comma-separated)
# CHAT_MAX_TURNS=20                 # Max tool-use turns for generic provider (default: 20)
# CHAT_MAX_TOOL_RESULT_CHARS=4000   # Max chars per tool result (default: 4000)
# CHAT_MAX_CONTEXT_TOKENS=60000     # Approx max context tokens before compaction (default: 60000)
# CHAT_FETCH_TIMEOUT=120            # Fetch timeout in seconds for generic provider (default: 120)
# CHAT_MAX_HISTORY_TOKENS=0         # Max tokens before history compaction, 0=disabled (default: 0)

# Additional providers (auto-discovered via PROVIDER_{NAME}_* pattern)
# PROVIDER_DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# PROVIDER_DEEPSEEK_API_KEY=sk-xxx
# PROVIDER_DEEPSEEK_MODEL=deepseek-chat
# PROVIDER_KIMI_API_BASE=https://api.moonshot.cn/v1
# PROVIDER_KIMI_API_KEY=sk-xxx
# PROVIDER_KIMI_MODEL=moonshot-v1-auto

# Notion skill (optional — enables notion skill)
# NOTION_API_KEY=ntn_xxx

# Lark Bot (optional — enables Lark channel)
# LARK_ENABLED=true                   # Set to "true" to enable Lark channel (default: false)
# LARK_APP_ID=cli_xxx
# LARK_APP_SECRET=xxx
# LARK_MODE=ws                       # "ws" (WebSocket long connection, default) or "webhook" (HTTP callback)
# LARK_VERIFICATION_TOKEN=xxx        # Required for webhook mode only
# LARK_OPEN_ID=ou_xxx               # Bot open_id (optional — skips API fetch if set)

# External MCP Servers (optional — configure in mcp-servers.json)
# See mcp-servers.example.json for format
